# Copy to .env and fill in. .env is gitignored.

# =============================================================================
# Postgres
# =============================================================================
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=app
POSTGRES_PORT=5432

# DATABASE_URL is what dbmate and app services read.
# Inside the compose network the host is "postgres".
DATABASE_URL=postgres://app:change_me_dev_only@postgres:5432/app?sslmode=disable

# =============================================================================
# LLM / embeddings
# =============================================================================
# Required. OpenRouter key — routes classifier + scorer (Gemini Flash), drafter
# + resume coach (Gemini 3.1 Pro), and embeddings (text-embedding-3-small).
# Get one at https://openrouter.ai.
OPENROUTER_API_KEY=

# =============================================================================
# Job-board API keys (optional — the scraper skips sources with missing keys)
# =============================================================================
# USAJobs: free, but requires the email you registered at developer.usajobs.gov.
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna: free tier = 1,000 requests/day. Register at developer.adzuna.com.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# =============================================================================
# Search scope
# =============================================================================
# Comma-separated keywords. JobSpy / Adzuna / USAJobs use the first one as their
# primary query; ATS direct + Remotive use the full list as a title filter. If
# left blank, ATS + Remotive yield every posting and JobSpy/Adzuna/USAJobs skip.
# Examples:
#   SEARCH_KEYWORDS=software engineer,backend,python
#   SEARCH_KEYWORDS=registered nurse,RN
#   SEARCH_KEYWORDS=product manager,PM
SEARCH_KEYWORDS=

# City + state (or region). Drives the scraper's location params and the
# location_bonus score. Leave blank if you're location-agnostic / remote-only.
#   SEARCH_LOCATION=San Francisco, CA
#   SEARCH_LOCATION=New York, NY
SEARCH_LOCATION=

# Distance in miles (JobSpy + Adzuna + USAJobs all respect this).
SEARCH_DISTANCE_MI=100

# =============================================================================
# Optional target-profile hints for the batch scorer agent (classifier cron)
# =============================================================================
# Injected into the scorer's system prompt when set. Without them the scorer
# falls back to generic signals. The resume coach in the dashboard (and the
# resume's embedding itself) is the primary way the system learns what you
# actually want — these env vars just give the batch scorer a starting point.
TARGET_FIELD=
TARGET_SENIORITY=
TARGET_PROFILE_NOTES=
